# ═══════════════════════════════════════════
# FITFORGE — Environment Variables Template
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./database/fitness.db

# User Defaults (used when seeding first user)
DEFAULT_USER_NAME=YourName
DEFAULT_USER_HEIGHT=175
DEFAULT_USER_WEIGHT=70
DEFAULT_USER_AGE=21
DEFAULT_USER_GENDER=male
DEFAULT_USER_ACTIVITY=moderate
DEFAULT_USER_GOAL=bulk

# CORS (comma-separated allowed origins, * for all)
CORS_ORIGIN=*

# Session / Security (for future auth expansion)
SESSION_SECRET=change_this_to_a_random_string
